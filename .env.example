# Data source: auto tries live search first, then falls back to the recorded fixture.
# Use cached for fully offline/demo runs; use live when refreshing from public search.
FS_SOURCE=auto

# Enrichment source. auto uses public web enrichment unless another provider is configured.
FS_ENRICH=auto

# Optional. The bundled LinkedIn provider is only a placeholder until wired to a real API.
FS_LINKEDIN_API_KEY=

# Extraction mode for `founder-signals run`: auto = regex first, LLM fills gaps.
# Without FS_LLM_API_KEY, auto safely falls back to regex.
FS_EXTRACT=auto
FS_LLM_API_KEY=
FS_LLM_BASE_URL=https://api.openai.com/v1
FS_LLM_MODEL=gpt-4o-mini
FS_LLM_RPM=60
FS_LLM_WORKERS=6

# Local output/state directory: exports, SQLite store, logs, cache, history.
FS_DATA_DIR=./data

# Minimum confidence required for exported founder records.
FS_MIN_CONFIDENCE=0.35

# Live search settings. Increase rate limit / lower results if DuckDuckGo throttles.
FS_RATE_LIMIT=1.2
FS_MAX_RETRIES=3
FS_TIMEOUT=12.0
FS_RESULTS_PER_QUERY=15
FS_USER_AGENT=founder-signals-research/0.1
